{
  "name": "@liguelead/mcp-server",
  "version": "1.0.1",
  "description": "MCP Server for LigueLead — SMS, SMS Flash & Voice campaigns in Brazil. Enables Claude, Cursor, and AI agents to send real communications via LigueLead API.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "liguelead",
    "sms",
    "sms-flash",
    "voice",
    "voice-call",
    "telephony",
    "cpaas",
    "brazil",
    "brazilian",
    "communication",
    "ai-tools",
    "claude",
    "cursor",
    "anthropic",
    "automation",
    "n8n",
    "notification"
  ],
  "license": "MIT",
  "homepage": "https://github.com/liguelead/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liguelead/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/liguelead/mcp/issues"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "server.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
